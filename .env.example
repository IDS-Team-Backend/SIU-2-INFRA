# ============================================================
# Plantilla de entorno del stack SIU.
# Copiar a .env.prod y .env.dev y completar (esos NO se versionan).
#   PROD: docker compose --env-file .env.prod up -d
#   DEV : docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.dev up -d
# ============================================================

# ---- Infra / despliegue (interpolado por docker-compose) ----
PROJECT_NAME=siu                  # proyecto Docker (prod: siu, dev: siu-dev) -> prefija volumenes
STACK_ENV=prod                    # etiqueta de entorno (prod | dev): nombres de contenedor y routers
ENV_FILE=.env.prod                # este mismo archivo; se inyecta dentro de los contenedores
PROJECT_ROOT=/opt/apps/siu        # raiz del repo (build context e init de mysql)
TRAEFIK_NETWORK=net-nammu         # red externa de Traefik
CERT_RESOLVER=myresolver          # certresolver de Traefik
FRONTEND_HOST=siu.ejemplo.com     # host publico del frontend
API_HOST=siu.api.ejemplo.com      # host publico de la api
FRONTEND_DOCKERFILE=./Dockerfile  # prod: ./Dockerfile | dev: ./Dockerfile.dev
API_DOCKERFILE=./Dockerfile       # prod: ./Dockerfile | dev: ./Dockerfile.dev
RESTART_POLICY=unless-stopped     # prod: unless-stopped | dev: "no"

# ---- Frontend ----
BACKEND_URL=http://api-siu-prod:5000   # nombre del contenedor api del MISMO entorno
FRONTEND_SECRET_KEY=cambiar-por-uno-random
BACKEND_TIMEOUT=10
FRONTEND_URL=https://siu.ejemplo.com   # URL pública del frontend (== https://${FRONTEND_HOST}); enlaces de emails

# ---- Seguridad (JWT) ----
JWT_SECRET_KEY=poner-una-frase-larga-y-secreta
JWT_ACCESS_TOKEN_EXPIRES_HOURS=2

# ---- MySQL (servidor) ----
MYSQL_ROOT_PASSWORD=cambiar
MYSQL_DATABASE=siu2_db
MYSQL_USER=cambiar
MYSQL_PASSWORD=cambiar

# ---- Conexion a la base (backend) ----
DB_HOST=mysql-siu-prod            # nombre del contenedor mysql del MISMO entorno
DB_PORT=3306
DB_USER=cambiar
DB_PASSWORD=cambiar
DB_NAME=siu2_db

# ---- Mailer (SMTP) ----
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USERNAME=noreply@ejemplo.com
SMTP_PASSWORD=cambiar
SMTP_SENDER=noreply@ejemplo.com
SMTP_USE_TLS=true

# ---- Reglas de negocio ----
DOMINIOS_EMAIL_PERMITIDOS=gmail.com,ejemplo.com
