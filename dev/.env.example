# Plantilla de config runtime DEV. Copiar a .env y completar (.env NO se versiona).
#   cp .env.example .env  &&  docker compose up -d
# Solo config que se inyecta en los contenedores; lo estructural vive en docker-compose.yml.

# ---- Frontend ----
BACKEND_URL=http://api-siu-dev:5000        # nombre del contenedor api del MISMO entorno
FRONTEND_SECRET_KEY=clave-dev
BACKEND_TIMEOUT=10
FRONTEND_URL=https://dev.siu.ejemplo.com   # URL publica (== el Host del frontend); enlaces de emails

# ---- Seguridad (JWT) ----
JWT_SECRET_KEY=dev-secreto-no-usar-en-prod
JWT_ACCESS_TOKEN_EXPIRES_HOURS=2

# ---- MySQL (servidor) ----
MYSQL_ROOT_PASSWORD=cambiar
MYSQL_DATABASE=siu2_db
MYSQL_USER=cambiar
MYSQL_PASSWORD=cambiar

# ---- Conexion a la base (backend) ----
DB_HOST=mysql-siu-dev                       # nombre del contenedor mysql del MISMO entorno
DB_PORT=3306
DB_USER=cambiar
DB_PASSWORD=cambiar
DB_NAME=siu2_db

# ---- Mailer (SMTP) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=test
SMTP_PASSWORD=test
SMTP_SENDER=noreply@ejemplo.com
SMTP_USE_TLS=false

# ---- Reglas de negocio ----
DOMINIOS_EMAIL_PERMITIDOS=gmail.com,ejemplo.com
